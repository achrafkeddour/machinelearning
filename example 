# Install required libraries
# pip install transformers

from transformers import pipeline

# Load the text file
file_path = "story.txt"  # Replace with your file path
try:
    with open(file_path, 'r', encoding='utf-8') as file:
        context = file.read()
        print(f"Loaded text from {file_path}.")
except FileNotFoundError:
    print(f"Error: File {file_path} not found. Please check the file path.")
    exit()

# Initialize the question-answering pipeline
qa_pipeline = pipeline("question-answering", model="distilbert-base-uncased")

# Start the chatbot
print("Chatbot: Hi! Ask me anything based on the text file. Type 'exit' to quit.")
while True:
    # Get user input
    question = input("You: ")
    if question.lower() in ['exit', 'quit']:
        print("Chatbot: Goodbye!")
        break
    
    # Answer the question using the QA pipeline
    try:
        answer = qa_pipeline(question=question, context=context)
        print("Chatbot:", answer['answer'])
    except Exception as e:
        print("Chatbot: Sorry, I couldn't understand that. Please try again.")